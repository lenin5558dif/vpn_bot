# Database
POSTGRES_USER=vpnapp
POSTGRES_PASSWORD=vpnapp
POSTGRES_DB=vpnapp
DATABASE_URL=postgresql+asyncpg://vpnapp:vpnapp@db:5432/vpnapp

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000
JWT_SECRET=change_me_use_secrets_token_urlsafe_32
JWT_ALG=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin
ADMIN_PASSWORD_HASH=

# Encryption (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Bot API Key (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
BOT_API_KEY=

# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# WireGuard
WG_INTERFACE=wg0
WG_ENDPOINT=your.domain.com:51820
WG_NETWORK=10.10.0.0/24
WG_MTU=1420
WG_KEEPALIVE=25
DEFAULT_SPEED_LIMIT_MBIT=20
SERVER_PUBLIC_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

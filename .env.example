# Database (SQLite by default)
DATABASE_URL=sqlite+aiosqlite:///./vpnapp.sqlite

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
JWT_SECRET=change_me_use_secrets_token_urlsafe_32
JWT_ALG=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin
ADMIN_PASSWORD_HASH=generate_with_python3_-c_"from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your_password'))"

# Encryption (generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Bot API Key (generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
BOT_API_KEY=

# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# WireGuard
WG_INTERFACE=awg0
WG_ENDPOINT=your.server.ip:443
WG_NETWORK=10.10.0.0/24
WG_MTU=1420
WG_KEEPALIVE=25
DEFAULT_SPEED_LIMIT_MBIT=100
SERVER_PUBLIC_KEY=

# Bot alerts
ALERTS_ENABLED=true
ALERTS_HEALTH_INTERVAL_SEC=60
ALERTS_DIAGNOSTIC_INTERVAL_SEC=300
ALERTS_FAILURE_THRESHOLD=3
ALERTS_TRAFFIC_24H_THRESHOLD_GB=50
ALERTS_DISK_WARN_PCT=80
ALERTS_DISK_RECOVERY_PCT=75
ALERTS_REPEAT_HOURS=6
ALERTS_STATE_FILE=/var/lib/vpn-tg-app/bot-alerts-state.json

# CORS
CORS_ORIGINS=http://localhost:3000
